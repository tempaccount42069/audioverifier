# Shared secret - must match the one in your Roblox game's server script
PROXY_SECRET=your_long_random_secret_here

# Your game's Universe ID (find on Creator Dashboard -> Experience -> copy from URL)
UNIVERSE_ID=1234567890

# API Keys as JSON array - one entry per account/group that owns audios
# Each key needs "assets" permission with Read+Write scope
# Example with two bot accounts:
API_KEYS=[{"name":"MainGroupBot","apiKey":"your_open_cloud_key_1"},{"name":"AltGroupBot","apiKey":"your_open_cloud_key_2"}]

# Port to run on (default 3000)
PORT=3000
